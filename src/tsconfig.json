{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"jsx": "preserve",
		"jsxImportSource": "vue",
		"lib": ["ESNext", "DOM"],
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src/**/*", "env.d.ts"],
	"exclude": ["node_modules"]
}
